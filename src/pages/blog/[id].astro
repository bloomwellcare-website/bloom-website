---
// このファイルはblog/[id].astroとして保存してください
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const NOTION_TOKEN = import.meta.env.NOTION_TOKEN;
  const NOTION_BLOG_DB = import.meta.env.NOTION_BLOG_DB;

  if (!NOTION_TOKEN || !NOTION_BLOG_DB) return [];

  try {
    const res = await fetch(`https://api.notion.com/v1/databases/${NOTION_BLOG_DB}/query`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${NOTION_TOKEN}`,
        'Notion-Version': '2022-06-28',
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        filter: {
          property: 'ステータス',
          status: { equals: '公開済み' }
        }
      })
    });
    const data = await res.json();
    return (data.results ?? []).map(page => ({ params: { id: page.id } }));
  } catch(e) {
    return [];
  }
}

const { id } = Astro.params;
const NOTION_TOKEN = import.meta.env.NOTION_TOKEN;

let post = null;
let blocks = [];

if (NOTION_TOKEN && id) {
  try {
    const pageRes = await fetch(`https://api.notion.com/v1/pages/${id}`, {
      headers: {
        'Authorization': `Bearer ${NOTION_TOKEN}`,
        'Notion-Version': '2022-06-28',
      }
    });
    const pageData = await pageRes.json();

    if (pageData.properties) {
      const props = pageData.properties;
      post = {
        title: props['タイトル']?.title?.[0]?.plain_text ?? '無題',
        category: props['カテゴリ']?.select?.name ?? '',
        date: props['公開日']?.date?.start ?? '',
        author: props['執筆者']?.rich_text?.[0]?.plain_text ?? '',
      };
    }

    const blocksRes = await fetch(`https://api.notion.com/v1/blocks/${id}/children`, {
      headers: {
        'Authorization': `Bearer ${NOTION_TOKEN}`,
        'Notion-Version': '2022-06-28',
      }
    });
    const blocksData = await blocksRes.json();
    blocks = blocksData.results ?? [];

  } catch(e) {}
}

function getText(richText) {
  return richText?.map(t => t.plain_text).join('') ?? '';
}

const categoryColor = post?.category === 'リハビリ' ? 'var(--sky)' : post?.category === '居宅介護支援' ? '#2a8a60' : 'var(--pink)';
const categoryBg = post?.category === 'リハビリ' ? 'var(--sky-pale)' : post?.category === '居宅介護支援' ? '#d8f0e8' : 'var(--pink-pale)';
---
<Layout title={post ? `${post.title} | ブルームブログ` : 'ブログ | ブルーム'}>

<article style="max-width: 760px; margin: 0 auto; padding: 3rem 1.5rem 5rem;">

  {!post ? (
    <div style="text-align:center; padding: 4rem 0;">
      <p style="color:var(--txt-muted);">記事が見つかりませんでした。</p>
      <a class="btn-flat" href="/blog">← ブログ一覧に戻る</a>
    </div>
  ) : (
    <>
      <nav style="font-size:13px; color:var(--txt-muted); margin-bottom:2rem;">
        <a href="/" style="color:var(--txt-muted);text-decoration:none;">ホーム</a>
        <span style="margin:0 0.5rem;">›</span>
        <a href="/blog" style="color:var(--txt-muted);text-decoration:none;">ブログ</a>
        <span style="margin:0 0.5rem;">›</span>
        <span>{post.title}</span>
      </nav>

      <div style="display:flex;align-items:center;gap:10px;margin-bottom:1.25rem;flex-wrap:wrap;">
        <span style={`background:${categoryBg};color:${categoryColor};font-size:11px;font-weight:700;padding:3px 12px;border-radius:99px;`}>{post.category}</span>
        <span style="font-size:13px;color:var(--txt-muted);">{post.date}</span>
        {post.author && <span style="font-size:13px;color:var(--txt-muted);">✍️ {post.author}</span>}
      </div>

      <h1 style="font-family:'Kaisei Decol',serif;font-size:clamp(22px,3.5vw,32px);font-weight:700;color:var(--txt-dark);line-height:1.5;margin-bottom:2.5rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
        {post.title}
      </h1>

      <div>
        {blocks.map(block => {
          const type = block.type;
          if (type === 'paragraph') {
            const text = getText(block.paragraph?.rich_text);
            return text ? <p style="font-size:15px;color:var(--txt-mid);line-height:2;margin-bottom:1.25rem;" set:html={text}></p> : null;
          }
          if (type === 'heading_2') {
            return <h2 style="font-family:'Kaisei Decol',serif;font-size:22px;font-weight:700;color:var(--txt-dark);margin:2rem 0 0.75rem;" set:html={getText(block.heading_2?.rich_text)}></h2>;
          }
          if (type === 'heading_3') {
            return <h3 style="font-size:18px;font-weight:700;color:var(--txt-dark);margin:1.5rem 0 0.5rem;" set:html={getText(block.heading_3?.rich_text)}></h3>;
          }
          if (type === 'bulleted_list_item') {
            return <ul style="padding-left:1.5rem;margin-bottom:0.5rem;"><li style="font-size:15px;color:var(--txt-mid);line-height:1.9;" set:html={getText(block.bulleted_list_item?.rich_text)}></li></ul>;
          }
          if (type === 'numbered_list_item') {
            return <ol style="padding-left:1.5rem;margin-bottom:0.5rem;"><li style="font-size:15px;color:var(--txt-mid);line-height:1.9;" set:html={getText(block.numbered_list_item?.rich_text)}></li></ol>;
          }
          if (type === 'quote') {
            return <blockquote style="border-left:4px solid var(--pink);padding:0.75rem 1.25rem;background:var(--pink-soft);border-radius:0 10px 10px 0;margin:1.25rem 0;font-size:15px;color:var(--txt-mid);line-height:1.9;" set:html={getText(block.quote?.rich_text)}></blockquote>;
          }
          if (type === 'divider') {
            return <hr style="border:none;border-top:1px dashed var(--border);margin:2rem 0;">;
          }
          if (type === 'image') {
            const url = block.image?.file?.url || block.image?.external?.url || '';
            const caption = getText(block.image?.caption);
            return url ? <figure style="margin:1.5rem 0;"><img src={url} alt={caption} style="width:100%;border-radius:12px;"><figcaption style="text-align:center;font-size:12px;color:var(--txt-muted);margin-top:0.5rem;">{caption}</figcaption></figure> : null;
          }
          return null;
        })}
      </div>

      <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border);">
        <a class="btn-flat" href="/blog">← ブログ一覧に戻る</a>
      </div>
    </>
  )}

</article>

</Layout>
