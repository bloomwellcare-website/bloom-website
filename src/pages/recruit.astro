---
// 採用情報ページ
// 公開・非公開の切り替えはNotionで管理します
// Notionの「ステータス」を「公開中」にすると表示、「非公開」にすると非表示
import Layout from '../layouts/Layout.astro';

// 採用情報の公開設定
// ✏️ 公開したい求人はここの published を true、非公開は false にしてください
// 将来的にはNotionで管理できるよう拡張可能です
const jobs = [
  {
    published: false, // ← trueにすると公開、falseにすると非表示
    title: '訪問看護師（正社員・パート）',
    type: '看護師',
    employment: '正社員・パート',
    description: '訪問看護ステーションブルームで一緒に働きませんか。経験者優遇。ブランクのある方も歓迎します。',
    conditions: [
      '給与：応相談',
      '勤務地：豊田市内',
      '勤務時間：8:30〜17:30（応相談）',
      '資格：看護師免許',
    ],
  },
  {
    published: false,
    title: '理学療法士・作業療法士',
    type: 'リハビリ',
    employment: '正社員・パート',
    description: '訪問リハビリに興味のある方、ぜひご連絡ください。',
    conditions: [
      '給与：応相談',
      '資格：PT・OT免許',
    ],
  },
  {
    published: false,
    title: 'ケアマネジャー',
    type: '居宅介護支援',
    employment: '正社員',
    description: '居宅介護支援事業所ブルームのケアマネジャーを募集しています。',
    conditions: [
      '給与：応相談',
      '資格：介護支援専門員',
    ],
  },
];

// 公開中の求人だけ抽出
const publishedJobs = jobs.filter(j => j.published);
---
<Layout title="採用情報 | ブルーム">

<section style="padding-top: 4rem;">
  <div class="si">
    <div class="shd">
      <div class="sen sen-p">Recruit</div>
      <h2 class="sttl">採用情報</h2>
      <p class="sdesc">「住み慣れた場所で暮らし続けたい」という方を支えるチームの一員になりませんか。</p>
    </div>

    {publishedJobs.length > 0 ? (
      <div style="display:flex; flex-direction:column; gap:1.5rem;">
        {publishedJobs.map(job => (
          <div style="background:white; border:1px solid var(--border); border-radius:16px; padding:2rem; box-shadow:0 2px 12px rgba(232,143,160,0.05);">
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:1rem;">
              <span style="background:var(--pink-pale); color:var(--pink); font-size:11px; font-weight:700; padding:3px 12px; border-radius:99px;">{job.type}</span>
              <span style="background:var(--sky-pale); color:var(--sky); font-size:11px; font-weight:700; padding:3px 12px; border-radius:99px;">{job.employment}</span>
            </div>
            <h3 style="font-family:'Kaisei Decol',serif; font-size:20px; font-weight:700; color:var(--txt-dark); margin-bottom:0.75rem;">{job.title}</h3>
            <p style="font-size:14px; color:var(--txt-muted); line-height:1.9; margin-bottom:1rem;">{job.description}</p>
            <ul style="list-style:none; display:flex; flex-direction:column; gap:0.4rem;">
              {job.conditions.map(c => (
                <li style="font-size:13.5px; color:var(--txt-mid); display:flex; gap:8px;">
                  <span style="color:var(--pink);">●</span>{c}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    ) : (
      <!-- 公開中の求人がない場合 -->
      <div style="background:white; border:2px dashed var(--border); border-radius:16px; padding:3rem; text-align:center;">
        <div style="font-size:48px; margin-bottom:1rem;">🌸</div>
        <h3 style="font-family:'Kaisei Decol',serif; font-size:20px; font-weight:700; color:var(--txt-dark); margin-bottom:0.75rem;">現在、募集中の求人はありません</h3>
        <p style="font-size:14px; color:var(--txt-muted); line-height:1.9;">
          求人情報は随時更新しています。<br>
          お気軽にお問い合わせください。
        </p>
        <div style="margin-top:1.5rem;">
          <a class="btn-main" href="/#contact">お問い合わせはこちら</a>
        </div>
      </div>
    )}
  </div>
</section>

</Layout>
